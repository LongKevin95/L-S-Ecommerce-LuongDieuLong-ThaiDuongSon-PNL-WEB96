{
  "info": {
    "name": "L&S Ecommerce Upload APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing avatar, shop, and product image upload endpoints. Import this file into Postman, run the login requests first, then choose local files for form-data fields that use type=file."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "customerEmail", "value": "customer@ls.com" },
    { "key": "customerPassword", "value": "123456" },
    { "key": "vendorEmail", "value": "vendor@ls.com" },
    { "key": "vendorPassword", "value": "123456" },
    { "key": "adminEmail", "value": "admin@ls.com" },
    { "key": "adminPassword", "value": "123456" },
    { "key": "customerToken", "value": "" },
    { "key": "vendorToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "vendorProductId", "value": "" },
    { "key": "shopId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.collectionVariables.set('customerToken', data.accessToken);",
                  "if (data.user?.id) pm.collectionVariables.set('customerId', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "POST /auth/login vendor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.collectionVariables.set('vendorToken', data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{vendorEmail}}\",\n  \"password\": \"{{vendorPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "POST /auth/login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.collectionVariables.set('adminToken', data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "User Upload",
      "item": [
        {
          "name": "PATCH /users/me upload avatar",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Customer Upload Test",
                  "type": "text"
                },
                { "key": "phone", "value": "0900000002", "type": "text" },
                {
                  "key": "bio",
                  "value": "Testing avatar upload from Postman",
                  "type": "text"
                },
                { "key": "avatar", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Choose a local image file for the avatar field before sending the request."
          }
        },
        {
          "name": "PATCH /users/me remove avatar",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "removeAvatar", "value": "true", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Shop Upload",
      "item": [
        {
          "name": "PUT /shops/me upload logo and banner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data?.id) pm.collectionVariables.set('shopId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "LS Demo Shop", "type": "text" },
                {
                  "key": "description",
                  "value": "Shop upload test from Postman",
                  "type": "text"
                },
                {
                  "key": "contactEmail",
                  "value": "vendor@ls.com",
                  "type": "text"
                },
                { "key": "phone", "value": "0900000001", "type": "text" },
                {
                  "key": "address",
                  "value": "{\"addressLine1\":\"123 Nguyen Trai\",\"city\":\"HCM City\",\"state\":\"HCM\",\"zipCode\":\"700000\",\"country\":\"Vietnam\"}",
                  "type": "text"
                },
                { "key": "logo", "type": "file", "src": [] },
                { "key": "banner", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/shops/me",
              "host": ["{{baseUrl}}"],
              "path": ["shops", "me"]
            },
            "description": "Choose image files for logo and banner before sending the request."
          }
        },
        {
          "name": "GET /shops/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/shops/me",
              "host": ["{{baseUrl}}"],
              "path": ["shops", "me"]
            }
          }
        },
        {
          "name": "PUT /shops/me remove logo and banner",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "LS Demo Shop", "type": "text" },
                { "key": "removeLogo", "value": "true", "type": "text" },
                { "key": "removeBanner", "value": "true", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/shops/me",
              "host": ["{{baseUrl}}"],
              "path": ["shops", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Vendor Product Upload",
      "item": [
        {
          "name": "GET /vendor/products/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/vendor/products/me",
              "host": ["{{baseUrl}}"],
              "path": ["vendor", "products", "me"]
            }
          }
        },
        {
          "name": "POST /vendor/products upload thumbnail and gallery",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data?.id) pm.collectionVariables.set('vendorProductId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Vendor Upload Demo Product",
                  "type": "text"
                },
                { "key": "category", "value": "electronics", "type": "text" },
                {
                  "key": "description",
                  "value": "Product created from upload Postman collection",
                  "type": "text"
                },
                { "key": "price", "value": "199", "type": "text" },
                { "key": "oldPrice", "value": "249", "type": "text" },
                { "key": "stock", "value": "5", "type": "text" },
                { "key": "thumbnail", "type": "file", "src": [] },
                { "key": "gallery", "type": "file", "src": [] },
                { "key": "gallery", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/vendor/products",
              "host": ["{{baseUrl}}"],
              "path": ["vendor", "products"]
            },
            "description": "Choose one thumbnail image and one or more gallery images before sending the request."
          }
        },
        {
          "name": "PATCH /vendor/products/:id update images",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Vendor Upload Demo Product Updated",
                  "type": "text"
                },
                { "key": "price", "value": "299", "type": "text" },
                { "key": "replaceGallery", "value": "true", "type": "text" },
                { "key": "thumbnail", "type": "file", "src": [] },
                { "key": "gallery", "type": "file", "src": [] },
                { "key": "gallery", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/vendor/products/{{vendorProductId}}",
              "host": ["{{baseUrl}}"],
              "path": ["vendor", "products", "{{vendorProductId}}"]
            },
            "description": "Use this request after creating a product. It replaces thumbnail and gallery with new images."
          }
        },
        {
          "name": "PATCH /vendor/products/:id remove thumbnail and clear gallery",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "removeThumbnail", "value": "true", "type": "text" },
                { "key": "replaceGallery", "value": "true", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/vendor/products/{{vendorProductId}}",
              "host": ["{{baseUrl}}"],
              "path": ["vendor", "products", "{{vendorProductId}}"]
            }
          }
        },
        {
          "name": "DELETE /vendor/products/:id",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/vendor/products/{{vendorProductId}}",
              "host": ["{{baseUrl}}"],
              "path": ["vendor", "products", "{{vendorProductId}}"]
            }
          }
        }
      ]
    }
  ]
}
